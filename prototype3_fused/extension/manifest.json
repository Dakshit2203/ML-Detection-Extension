{
  "manifest_version": 3,
  "name": "Two-Tower Phishing Detector (Prototype 3)",
  "version": "1.0.0",
  "description": "Full hybrid phishing detection: URL lexical analysis (Tower A) fused with domain metadata (Tower B), with per-feature explanations.",

  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "webNavigation"
  ],

  "host_permissions": [
    "http://127.0.0.1:8002/*"
  ],

  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Two-Tower: not scanned",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
